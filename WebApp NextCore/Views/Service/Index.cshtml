@model IEnumerable<ServiceModel>

<h2 class="text-center mb-4">Наши услуги</h2>

<div class="row">
    @foreach (var s in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow h-100">
                <div class="card-body text-center">
                    <h5 class="mt-3">@s.Title</h5>
                    <p>@s.Description</p>
                </div>
            </div>
        </div>
    }
</div>