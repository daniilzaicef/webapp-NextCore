@model IEnumerable<ServiceModel>

@{
    ViewData["Title"] = "Услуги";
}

<div class="container mt-5">

    <!-- Заголовок -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">Наши услуги</h1>
        <p class="text-muted">
            Мы предлагаем широкий спектр IT-услуг для вашего бизнеса
        </p>
    </div>

    <!-- Карточки -->
    <div class="row g-4">

        @foreach (var service in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm service-card">

                    <div class="card-body text-center">

                        <!-- Иконка -->
                        <div class="mb-3">
                            <i class="bi bi-gear-fill display-5 text-primary"></i>
                        </div>

                        <!-- Название -->
                        <h5 class="card-title fw-bold">
                            @service.Title
                        </h5>

                        <!-- Описание -->
                        <p class="card-text text-muted">
                            @service.Description
                        </p>

                        <!--Подробное описание-->
                        <a asp-action="Details"
                           asp-route-id="@service.Id"
                           class="btn btn-outline-primary mt-3">
                            Подробнее
                        </a>

                    </div>

                </div>
            </div>
        }

    </div>

</div>