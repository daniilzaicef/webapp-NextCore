@model WebApp_NextCore.Models.ServiceModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">

    <div class="card shadow-lg p-4">

        <!-- Заголовок -->
        <div class="text-center mb-4">
            <h1 class="fw-bold mt-3">@Model.Title</h1>
        </div>

        <!-- Описание -->
        <p class="text-muted fs-5 text-center">
            @Model.Description
        </p>

        <!-- Дополнительный текст -->
        <div class="mt-4">
            <h4>Подробное описание</h4>
            <p>
                @Model.FullDescription
            </p>
        </div>

        <!-- Кнопки -->
        <div class="text-center mt-4">
            <a asp-controller="ServiceRequest" asp-action="Create" asp-route-serviceId="@Model.Id"
               class="btn btn-primary me-2">
                Заказать услугу
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Назад
            </a>
        </div>

    </div>

</div>