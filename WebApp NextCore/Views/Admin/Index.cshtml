@model IEnumerable<VacancyModel>

<h2>Вакансии</h2>

<a asp-action="Create" class="btn btn-success">Добавить</a>

<table class="table">
    <tr>
        <th>Название</th>
        <th>Описание</th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Редактировать</a> |
                <a href="#" onclick="confirmDelete(@item.Id)">Удалить</a>
            </td>
        </tr>
    }
</table>

<script>
    function confirmDelete(id) {
        if (confirm('Вы уверены, что хотите удалить эту вакансию?')) {
            // Создаём форму, чтобы отправить POST-запрос
            var form = document.createElement('form');
            form.method = 'post';
            form.action = '/Admin/Delete/' + id;
            var antiForgeryToken = document.createElement('input');
            antiForgeryToken.type = 'hidden';
            antiForgeryToken.name = '__RequestVerificationToken';
            antiForgeryToken.value = '@Html.AntiForgeryToken()';
            form.appendChild(antiForgeryToken);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
