@{
    ViewData["Title"] = "О нас";
}

<div class="container mt-5">

    <!-- Заголовок -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">О нас</h1>
        <p class="text-muted">
            Мы создаем современные IT-решения для бизнеса
        </p>
    </div>

    <!-- Блок: кто мы -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h3 class="fw-bold">Кто мы</h3>
            <p>
                Мы команда разработчиков, специализирующаяся на создании
                веб-приложений, корпоративных систем и цифровых сервисов.
            </p>
        </div>
    </div>

    <!-- Блок: преимущества -->
    <div class="mb-5">
        <h3 class="text-center fw-bold mb-4">Почему выбирают нас</h3>

        <div class="row text-center">

            <div class="col-md-4">
                <div class="card p-4 shadow h-100">
                    <h4>🚀</h4>
                    <h5>Современные технологии</h5>
                    <p class="text-muted">
                        Используем .NET, SQL и актуальные веб-технологии
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 shadow h-100">
                    <h4>💡</h4>
                    <h5>Индивидуальный подход</h5>
                    <p class="text-muted">
                        Подстраиваем решения под задачи клиента
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 shadow h-100">
                    <h4>🔒</h4>
                    <h5>Надежность</h5>
                    <p class="text-muted">
                        Гарантируем стабильность и безопасность проектов
                    </p>
                </div>
            </div>

        </div>
    </div>

    <!-- Блок: статистика -->
    <div class="bg-light p-5 rounded text-center mb-5">
        <div class="row">

            <div class="col-md-4">
                <h2 class="fw-bold">10+</h2>
                <p>Проектов</p>
            </div>

            <div class="col-md-4">
                <h2 class="fw-bold">5+</h2>
                <p>Клиентов</p>
            </div>

            <div class="col-md-4">
                <h2 class="fw-bold">2+</h2>
                <p>Года опыта</p>
            </div>

        </div>
    </div>
</div>